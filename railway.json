{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "restartPolicyType": "on_failure",
    "healthcheckPath": "/api/ping",
    "volumes": [
      {
        "mountPath": "/app/uploads",
        "name": "chileme-uploads"
      }
    ]
  }
}
