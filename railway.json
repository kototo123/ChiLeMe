{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "buildContext": "backend",
    "watchPatterns": ["backend/**"]
  },
  "deploy": {
    "restartPolicyType": "on_failure",
    "healthcheckPath": "/api/health",
    "startCommand": "cd backend && java -jar target/*.jar"
  }
}
